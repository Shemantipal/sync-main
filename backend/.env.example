# --- Server ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info

# Comma-separated list of allowed origins for CORS (no trailing slash)
CORS_ORIGINS=http://localhost:3000

# Public URL of this backend (used in emails for links to docs/health)
APP_URL=http://localhost:4000

# Public URL of the frontend (used in password reset / invitation emails)
FRONTEND_URL=http://localhost:3000

# --- MongoDB ---
# Local docker compose: mongodb://localhost:27017/sync
# Atlas:                 mongodb+srv://user:pass@cluster.mongodb.net/sync
MONGO_URI=mongodb://localhost:27017/sync

# --- JWT ---
# Generate fresh ones for production: `openssl rand -base64 64`
JWT_ACCESS_SECRET=6oQmsUFnXlguIut8tx/vqSZXDLmuYP55k0bYxr7eB0Zhz2TIS7NJPv/GMQivI1Bvr4A12nLj0f2Qw5Cxlyet8A==
JWT_REFRESH_SECRET=h/cCjtdvozyZQ35ln7rUpwh9XnIlF7V7H4kJiq/e8NzyxjL136q+QufvawaBdga80PruZYSsGrl/Qhh7x6EBGg==
JWT_RESET_SECRET=jcg4Dhl5azg1YTYA3M5qa4ZVa4w3oCibbo7940LlT/cRCFUhl4xpzQXH/K0jaqHxSFM2blvZ7qUcKt6HBLZYCg==
JWT_INVITE_SECRET=wRChJ96SezHcRfdM8BrsafHT97aCjLXC6ZUiNeiTa4v+99oBsFlZFdyIQjVI+zDjjtdHRnVLLnnGVRbnEQS54A==
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
RESET_TOKEN_TTL=30m
INVITE_TOKEN_TTL=7d

# --- Cookies ---
# COOKIE_PATH must match the BROWSER-VISIBLE auth URL so the browser sends the cookie back.
#   Local dev / Render-only:        /api/auth
#   Vercel single-deploy (this app): /_/backend/api/auth
COOKIE_PATH=/api/auth
COOKIE_DOMAIN=
COOKIE_SECURE=false
# COOKIE_SAMESITE override (optional):
#   `lax`  — same-origin (Vercel single-deploy)
#   `none` — cross-origin (Vercel + Render). Requires COOKIE_SECURE=true.
# If unset, auto-picked from COOKIE_SECURE: secure → none, else → lax.
# COOKIE_SAMESITE=

# ============================================================================
#  STORAGE — pick `cloudinary` (production) or `s3` (local Docker / MinIO)
# ============================================================================
STORAGE_PROVIDER=s3

# --- Cloudinary (only used when STORAGE_PROVIDER=cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=sync

# --- S3-compatible (MinIO defaults from docker-compose.yml) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=sync
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL_BASE=http://localhost:9000/sync

# ============================================================================
#  EMAIL — pick `resend` (production), `smtp` (local Docker / Mailpit), or
#  `console` (just log emails, no delivery)
# ============================================================================
EMAIL_PROVIDER=resend

# --- Resend (only used when EMAIL_PROVIDER=resend) ---
RESEND_API_KEY=re_RjHg1YoG_P33X7MHVNTgM6Mxe9jXv29wm
RESEND_FROM="no-reply.kabootr.com"

# --- SMTP (Mailpit defaults from docker-compose.yml) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="SYNC <noreply@local.test>"

# --- Rate limits (requests per window) ---
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=300
RATE_LIMIT_GLOBAL_WINDOW_MS=900000

# --- Uploads ---
MAX_FILE_SIZE_MB=5
