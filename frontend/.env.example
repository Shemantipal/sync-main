# ─── Frontend env ──────────────────────────────────────────────────────────
# Pick ONE of the API URL patterns below.

# (A) Vercel single-deploy — backend at /_/backend on the same Vercel domain.
#     Relative path keeps preview deploys working without per-deploy config.
NEXT_PUBLIC_API_URL=/_/backend

# (B) Separate backend on Render — uncomment and point at your Render URL:
# NEXT_PUBLIC_API_URL=https://your-backend.onrender.com

# (C) Local dev with backend on :4000:
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Optional: explicit Socket.io path. If unset, the client derives:
#   absolute NEXT_PUBLIC_API_URL → /socket.io/
#   relative NEXT_PUBLIC_API_URL → <prefix>/socket.io/
# Uncomment ONLY if you need to override:
# NEXT_PUBLIC_SOCKET_PATH=/_/backend/socket.io/
